# ekubo-arb — example environment configuration
# Copy to .env and fill in your values: cp .env.example .env
RUST_LOG=info

# Required: Starknet JSON-RPC endpoint
APP_RPC_URL=https://starknet-mainnet.g.alchemy.com/v2/<api-key>

# Required: WebSocket URL for real-time event streaming
APP_RPC_WS_URL=wss://starknet-mainnet.g.alchemy.com/v2/<api-key>

# Required: Account address for transaction signing (hex format)
APP_ACCOUNT_ADDRESS=0x123

# Required: Private key for the account (hex format)
APP_ACCOUNT_PRIVATE_KEY=0x123

# Required: Starting block number — loads {block}.json and syncs from block+1
APP_FROM_BLOCK=6880900

# Minimum profit threshold in hundredth basis points (100 = 1 bip = 0.01%)
APP_MIN_PROFIT_HBIP=100

# Broadcast transactions on-chain
APP_BROADCAST=false

# Health server port (default: 8080)
APP_HEALTH_PORT=8080

# Log format: "json" for structured JSON, omit for human-readable
# APP_LOG_FORMAT=json
